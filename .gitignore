# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example は公開してよい
.env
.env.local
.env.*.local
# .env.example は除外しない（公開テンプレート）

# vercel
.vercel

# prisma — ローカル SQLite ファイル（コミットしない）
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm
public/sw.js
public/sw.js.map

# typescript
*.tsbuildinfo
next-env.d.ts
