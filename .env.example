# ── データベース ────────────────────────────────────────────
# Neon (https://neon.tech) の接続文字列を貼る
# 例: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── 認証・セキュリティ ─────────────────────────────────────
# openssl rand -base64 32 で生成した文字列（本番では必ず変更）
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Vercel Cron の保護用シークレット
CRON_SECRET="change-me"

# ── 座標（日の出/日の入り計算・地図初期位置） ────────────────
# 家島真浦港付近
NEXT_PUBLIC_ISLAND_LAT="34.683"
NEXT_PUBLIC_ISLAND_LNG="134.530"
